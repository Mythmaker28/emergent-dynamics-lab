\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {Model and causal--intervention ladder (schematic).} Question: what are the write/read pathways and interventions? Frozen C1c architecture: experience signal $\Psi $ (Eq.\nobreakspace  {}\ref  {eq:psi}); two--timescale memory $m=(m_1,m_2)$ (Eq.\nobreakspace  {}\ref  {eq:write}); readouts $m_+\!\to $uptake and $m_-\!\to $attractant (Eqs.\nobreakspace  {}\ref  {eq:readplus}--\ref  {eq:readminus}); and the intervention suite (erase, transplant, ablation, pulse--chase, clone). Schematic; no data. Source: \texttt  {docs/paper/fig1\_model\_ladder.png}.\relax }}{13}{figure.caption.27}\protected@file@percent }
\newlabel{fig:model}{{1}{13}{\textbf {Model and causal--intervention ladder (schematic).} Question: what are the write/read pathways and interventions? Frozen C1c architecture: experience signal $\Psi $ (Eq.~\ref {eq:psi}); two--timescale memory $m=(m_1,m_2)$ (Eq.~\ref {eq:write}); readouts $m_+\!\to $uptake and $m_-\!\to $attractant (Eqs.~\ref {eq:readplus}--\ref {eq:readminus}); and the intervention suite (erase, transplant, ablation, pulse--chase, clone). Schematic; no data. Source: \texttt {docs/paper/fig1\_model\_ladder.png}.\relax }{figure.caption.27}{}}
\citation{turing1952,zwicker2017}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {$h_1$ is causally expressed and transplantable.} Protocol: mean transplant of donor memory into a fresh standardized erased body, in--place memory--isolated response (full minus memory--inert), and the memory--inert control. Prospective, grouped leave--history--out, $n=12$ histories. Held--out $h_1$ response $R^2=0.61$ (transplant), $0.50$ (in--place); the memory--inert control collapses it (causal necessity). Uncertainty: donor--level. Limitation: mean--field readout. Data: \texttt  {results/wd01\_phasec/phasec\_causal\_*\_raw.pkl}; script \texttt  {causal\_runner.py}.\relax }}{14}{figure.caption.28}\protected@file@percent }
\newlabel{fig:causal}{{2}{14}{\textbf {$h_1$ is causally expressed and transplantable.} Protocol: mean transplant of donor memory into a fresh standardized erased body, in--place memory--isolated response (full minus memory--inert), and the memory--inert control. Prospective, grouped leave--history--out, $n=12$ histories. Held--out $h_1$ response $R^2=0.61$ (transplant), $0.50$ (in--place); the memory--inert control collapses it (causal necessity). Uncertainty: donor--level. Limitation: mean--field readout. Data: \texttt {results/wd01\_phasec/phasec\_causal\_*\_raw.pkl}; script \texttt {causal\_runner.py}.\relax }{figure.caption.28}{}}
\@writefile{toc}{\contentsline {section}{\numberline {7}Limitations}{14}{section.7}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {Longitudinally--tracked turnover.} Question: does a single tracked droplet retain $h_1$ as its material is replaced? Protocol: frozen C1c, untouched seed $38502$, longitudinal tracker. The tracked entity (red contour) is shown on the body panel and, with the \emph  {same} contour, on the old/new--material panel (orange/red $=$ original, blue $=$ new, white $=$ empty); the time series shows old--material fraction $M$ declining, mean $m_+$ ($h_1$) rising, and stable size. Single deterministic trajectory (illustrative); population certification is Figure\nobreakspace  {}\ref  {fig:cert}. Data/script: \texttt  {scripts/observe\_droplet.py}.\relax }}{15}{figure.caption.29}\protected@file@percent }
\newlabel{fig:track3}{{3}{15}{\textbf {Longitudinally--tracked turnover.} Question: does a single tracked droplet retain $h_1$ as its material is replaced? Protocol: frozen C1c, untouched seed $38502$, longitudinal tracker. The tracked entity (red contour) is shown on the body panel and, with the \emph {same} contour, on the old/new--material panel (orange/red $=$ original, blue $=$ new, white $=$ empty); the time series shows old--material fraction $M$ declining, mean $m_+$ ($h_1$) rising, and stable size. Single deterministic trajectory (illustrative); population certification is Figure~\ref {fig:cert}. Data/script: \texttt {scripts/observe\_droplet.py}.\relax }{figure.caption.29}{}}
