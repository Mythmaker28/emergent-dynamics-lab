\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {Longitudinal hold--out certification.} Untouched sealed seeds $38502$--$38504$, $n=12$ histories $\times 3$ seeds, executed once. $h_1$ held--out $R^2$ with $95\%$ CI versus $M$ (stays $\approx 0.98$ to $M\approx 0.19$); $100\%$ track survival ($36/36$); sensitivity table (largest vs longitudinal). Prospective, grouped, donor--level bootstrap CIs. Result: $h_1$ certified; $h_2<0.5$. Data: \texttt  {results/observer/tca\_holdout\_raw.pkl}.\relax }}{16}{figure.caption.30}\protected@file@percent }
\newlabel{fig:cert}{{4}{16}{\textbf {Longitudinal hold--out certification.} Untouched sealed seeds $38502$--$38504$, $n=12$ histories $\times 3$ seeds, executed once. $h_1$ held--out $R^2$ with $95\%$ CI versus $M$ (stays $\approx 0.98$ to $M\approx 0.19$); $100\%$ track survival ($36/36$); sensitivity table (largest vs longitudinal). Prospective, grouped, donor--level bootstrap CIs. Result: $h_1$ certified; $h_2<0.5$. Data: \texttt {results/observer/tca\_holdout\_raw.pkl}.\relax }{figure.caption.30}{}}
