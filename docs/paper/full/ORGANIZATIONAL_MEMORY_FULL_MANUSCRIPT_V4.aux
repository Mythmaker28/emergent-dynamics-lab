\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces \textbf  {$h_2$ deep--turnover (canonical pipeline).} Held--out $h_2$ decode versus surviving original--material fraction $M$ with $95\%$ bootstrap CIs; dashed line is the $0.50$ qualification threshold and the shaded band is below it. At deep turnover the canonical longitudinal $h_2=-0.24$ has CI $[-0.78,0.32]$, lying below the threshold, so deep--turnover retention is \emph  {not established} --- this bounds the C1c architecture and this dispersion metric, and is not a demonstrated absence of all order information nor a substrate--level impossibility. Generated by \texttt  {python -m reproduction.primary} from \texttt  {results/observer/tca\_holdout\_raw.pkl}.\relax }}{20}{figure.caption.35}\protected@file@percent }
\newlabel{fig:killswitch}{{7}{20}{\textbf {$h_2$ deep--turnover (canonical pipeline).} Held--out $h_2$ decode versus surviving original--material fraction $M$ with $95\%$ bootstrap CIs; dashed line is the $0.50$ qualification threshold and the shaded band is below it. At deep turnover the canonical longitudinal $h_2=-0.24$ has CI $[-0.78,0.32]$, lying below the threshold, so deep--turnover retention is \emph {not established} --- this bounds the C1c architecture and this dispersion metric, and is not a demonstrated absence of all order information nor a substrate--level impossibility. Generated by \texttt {python -m reproduction.primary} from \texttt {results/observer/tca\_holdout\_raw.pkl}.\relax }{figure.caption.35}{}}
