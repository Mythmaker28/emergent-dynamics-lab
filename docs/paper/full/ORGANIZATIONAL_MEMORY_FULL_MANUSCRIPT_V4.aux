\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {Primary quantitative result: longitudinal hold--out certification.} Untouched sealed seeds $38502$--$38504$, $n=12$ histories $\times 3$ seeds, executed once. $h_1$ held--out $R^2$ with $95\%$ CI versus $M$ (deep $0.89$ [$0.84,0.96$] at $M\approx 0.19$); $h_2$ below threshold ($-0.24$ [$-0.78,0.32$]); $100\%$ track survival ($36/36$, $0$ switches). Prospective held--out trajectories; donor--level bootstrap CIs. Generated by \texttt  {python -m reproduction.primary} from \texttt  {results/observer/tca\_holdout\_raw.pkl}.\relax }}{17}{figure.caption.31}\protected@file@percent }
\newlabel{fig:cert}{{4}{17}{\textbf {Primary quantitative result: longitudinal hold--out certification.} Untouched sealed seeds $38502$--$38504$, $n=12$ histories $\times 3$ seeds, executed once. $h_1$ held--out $R^2$ with $95\%$ CI versus $M$ (deep $0.89$ [$0.84,0.96$] at $M\approx 0.19$); $h_2$ below threshold ($-0.24$ [$-0.78,0.32$]); $100\%$ track survival ($36/36$, $0$ switches). Prospective held--out trajectories; donor--level bootstrap CIs. Generated by \texttt {python -m reproduction.primary} from \texttt {results/observer/tca\_holdout\_raw.pkl}.\relax }{figure.caption.31}{}}
