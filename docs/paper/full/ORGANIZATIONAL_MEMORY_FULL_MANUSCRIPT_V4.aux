\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {Model and causal--intervention ladder (schematic).} Question: what are the write/read pathways and interventions? Frozen C1c architecture: experience signal $\Psi $ (Eq.\nobreakspace  {}\ref  {eq:psi}); two--timescale memory $m=(m_1,m_2)$ (Eq.\nobreakspace  {}\ref  {eq:write}); readouts $m_+\!\to $uptake and $m_-\!\to $attractant (Eqs.\nobreakspace  {}\ref  {eq:readplus}--\ref  {eq:readminus}); and the intervention suite (erase, transplant, ablation, pulse--chase, clone). Schematic; no data. Source: \texttt  {docs/paper/fig1\_model\_ladder.png}.\relax }}{14}{figure.caption.28}\protected@file@percent }
\newlabel{fig:model}{{1}{14}{\textbf {Model and causal--intervention ladder (schematic).} Question: what are the write/read pathways and interventions? Frozen C1c architecture: experience signal $\Psi $ (Eq.~\ref {eq:psi}); two--timescale memory $m=(m_1,m_2)$ (Eq.~\ref {eq:write}); readouts $m_+\!\to $uptake and $m_-\!\to $attractant (Eqs.~\ref {eq:readplus}--\ref {eq:readminus}); and the intervention suite (erase, transplant, ablation, pulse--chase, clone). Schematic; no data. Source: \texttt {docs/paper/fig1\_model\_ladder.png}.\relax }{figure.caption.28}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {$h_1$ causal expression (necessity established; sufficiency magnitude uncertain).} Left: per--history predicted--versus--observed $h_1$ (held--out, $n=12$), for the active memory (green) and the memory--inert control (grey, no information). Right: bootstrap distribution of the transplant $R^2$ (point $0.61$; $95\%$ CI $[-0.69,0.87]$, spanning $0.5$), showing the magnitude is not tightly established at $n=12$. Causal necessity is clean: the inert and erase controls carry no history information (deterministic $R^2=-0.19$). Prospective, grouped leave--history--out; $n_{\text  {boot}}=3000$; ridge $\lambda =1$. Data: \texttt  {results/wd01\_phasec/phasec\_causal\_*\_raw.pkl}.\relax }}{15}{figure.caption.29}\protected@file@percent }
\newlabel{fig:causal}{{2}{15}{\textbf {$h_1$ causal expression (necessity established; sufficiency magnitude uncertain).} Left: per--history predicted--versus--observed $h_1$ (held--out, $n=12$), for the active memory (green) and the memory--inert control (grey, no information). Right: bootstrap distribution of the transplant $R^2$ (point $0.61$; $95\%$ CI $[-0.69,0.87]$, spanning $0.5$), showing the magnitude is not tightly established at $n=12$. Causal necessity is clean: the inert and erase controls carry no history information (deterministic $R^2=-0.19$). Prospective, grouped leave--history--out; $n_{\text {boot}}=3000$; ridge $\lambda =1$. Data: \texttt {results/wd01\_phasec/phasec\_causal\_*\_raw.pkl}.\relax }{figure.caption.29}{}}
