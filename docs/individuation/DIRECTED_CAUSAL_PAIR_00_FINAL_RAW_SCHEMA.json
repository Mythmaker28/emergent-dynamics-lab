      }
    },
    "world_complete": {
      "type": "boolean"
    },
    "first_failure": {
      "$ref": "#/$defs/nullable_failure"
    }
  },
  "allOf": [
    {
      "if": {"properties": {"world_complete": {"const": true}}},
      "then": {
        "properties": {
          "common_deep_step": {"type": "integer", "minimum": 1},
          "first_failure": {"type": "null"}
        }
      },
      "else": {
        "properties": {
          "first_failure": {"$ref": "#/$defs/failure"}
        }
      }
    }
  ],
  "$defs": {
