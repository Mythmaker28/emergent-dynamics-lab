{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "DIRECTED-CAUSAL-PAIR-00-PHASE05-FINAL-RAW-SCHEMA-v1",
  "title": "DIRECTED-CAUSAL-PAIR-00 Phase 0.5 mechanical world shard",
  "description": "Strict mechanical-only DEV raw. One shard is one original world. Scientific response, feeding, directed contrasts, interactions, estimands, readers, decoders, and analyzers are structurally absent.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "mission",
    "mode",
    "phase0_commit",
    "world_id",
    "sequence_index",
    "manifest_sha256",
    "plan_sha256",
    "previous_record_sha256",
    "contract_bindings",
    "assignment",
    "prewriter_state_sha256",
    "prewriter_clone_sha256",
    "writer",
    "common_deep_step",
    "history_arms",
    "world_complete",
    "first_failure"
  ],
  "properties": {
    "schema": {
      "const": "DIRECTED-CAUSAL-PAIR-00-PHASE05-MECHANICAL-SHARD-v1"
    },
    "mission": {
      "const": "DIRECTED-CAUSAL-PAIR-00"
    },
    "mode": {
      "const": "DEV_ONLY_MECHANICAL"
    },
    "phase0_commit": {
      "const": "4bcb551092291b7383c4168f653818d4bade14f6"
    },
    "world_id": {
      "enum": [50002, 50004, 50005, 50007]
    },
    "sequence_index": {
      "type": "integer",
      "minimum": 0,
      "maximum": 3
    },
    "manifest_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "plan_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "previous_record_sha256": {
      "oneOf": [
        {"$ref": "#/$defs/sha256"},
        {"type": "null"}
      ]
    },
    "contract_bindings": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/contract_binding"}
    },
    "assignment": {
      "$ref": "#/$defs/root_assignment"
    },
    "prewriter_state_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "prewriter_clone_sha256": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {"$ref": "#/$defs/sha256"}
    },
    "writer": {
      "$ref": "#/$defs/root_writer"
    },
    "common_deep_step": {
      "oneOf": [
        {"type": "integer", "minimum": 1},
        {"type": "null"}
      ]
    },
    "history_arms": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
