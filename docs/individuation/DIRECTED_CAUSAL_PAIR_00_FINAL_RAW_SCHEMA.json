        "right_core_sha256": {"$ref": "#/$defs/sha256"},
        "left_state_sha256": {"$ref": "#/$defs/sha256"},
        "free_up_ref_state_sha256": {
          "oneOf": [
            {"$ref": "#/$defs/sha256"},
            {"type": "null"}
          ]
        }
      }
    },
    "environment_perturbation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fields", "amplitude"],
      "properties": {
        "fields": {"const": ["c", "N"]},
        "amplitude": {"const": 0.05}
      }
    },
    "isolation_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "recipient",
        "barrier_width",
        "up_ref_zero",
        "environment_perturbation",
        "per_step",
        "maximum_core_abs_difference",
        "environment_c_max_difference_at_end",
        "outside_difference_nonzero",
        "own_replay_up_ref_zero_exact",
        "left_first_failure",
        "right_first_failure",
        "bit_exact_isolation"
      ],
      "properties": {
        "recipient": {"enum": ["A", "B"]},
        "barrier_width": {"const": 2},
        "up_ref_zero": {"const": true},
        "environment_perturbation": {"$ref": "#/$defs/environment_perturbation"},
        "per_step": {
          "type": "array",
          "minItems": 80,
          "maxItems": 80,
          "items": {"$ref": "#/$defs/isolation_step"}
        },
        "maximum_core_abs_difference": {"type": "number", "minimum": 0.0},
        "environment_c_max_difference_at_end": {"type": "number", "minimum": 0.0},
        "outside_difference_nonzero": {"type": "boolean"},
        "own_replay_up_ref_zero_exact": {"type": "boolean"},
        "left_first_failure": {"$ref": "#/$defs/nullable_isolation_failure"},
        "right_first_failure": {"$ref": "#/$defs/nullable_isolation_failure"},
        "bit_exact_isolation": {"type": "boolean"}
      }
    },
    "access_regime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "regime",
        "recipient",
        "schedule",
        "operation",
        "records",
        "complete",
        "probe_schedule_viable",
        "first_failure",
        "isolation_evidence"
      ],
      "properties": {
        "regime": {
          "enum": [
            "ORDINARY",
            "OWN_REPLAY_SHAM_A",
            "OWN_REPLAY_SHAM_B",
            "REFERENCE_NOSWAP_A",
            "REFERENCE_NOSWAP_B",
            "UP_REF_ZERO",
            "REFERENCE_NOSWAP_A_UP_REF_ZERO",
            "REFERENCE_NOSWAP_B_UP_REF_ZERO"
          ]
        },
        "recipient": {
          "oneOf": [
            {"enum": ["A", "B"]},
            {"type": "null"}
          ]
        },
        "schedule": {"$ref": "#/$defs/probe_schedule"},
        "operation": {"$ref": "#/$defs/operation"},
        "records": {
          "type": "array",
          "minItems": 1,
          "maxItems": 81,
          "items": {"$ref": "#/$defs/step_record"}
        },
        "complete": {"type": "boolean"},
        "probe_schedule_viable": {"type": "boolean"},
        "first_failure": {"$ref": "#/$defs/nullable_failure"},
        "isolation_evidence": {
          "oneOf": [
            {"$ref": "#/$defs/isolation_evidence"},
            {"type": "null"}
          ]
        }
      },
      "allOf": [
        {
          "if": {"properties": {"complete": {"const": true}}},
          "then": {
            "properties": {
              "records": {"type": "array", "minItems": 81, "maxItems": 81},
              "probe_schedule_viable": {"const": true},
              "first_failure": {"type": "null"}
            }
          },
          "else": {
            "properties": {
              "probe_schedule_viable": {"const": false},
              "first_failure": {"$ref": "#/$defs/failure"}
            }
          }
        }
      ]
    },
    "history_arm": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "arm",
        "bits",
        "clone_sha256",
        "writer",
        "writer_records",
        "common_deep_step",
        "deep_complete",
        "deep_joint",
        "turnover_records",
        "access_regimes",
        "arm_complete",
        "first_failure"
      ],
      "properties": {
        "arm": {"enum": ["H00", "H10", "H01", "H11"]},
        "bits": {
          "type": "array",
          "prefixItems": [
            {"type": "integer", "enum": [0, 1]},
            {"type": "integer", "enum": [0, 1]}
          ],
          "items": false,
          "minItems": 2,
          "maxItems": 2
        },
        "clone_sha256": {"$ref": "#/$defs/sha256"},
        "writer": {"$ref": "#/$defs/arm_writer"},
        "writer_records": {
          "type": "array",
          "minItems": 1,
          "maxItems": 241,
          "items": {"$ref": "#/$defs/step_record"}
        },
        "common_deep_step": {
          "oneOf": [
            {"type": "integer", "minimum": 1},
            {"type": "null"}
          ]
        },
        "deep_complete": {"type": "boolean"},
        "deep_joint": {
          "oneOf": [
            {
              "type": "array",
              "minItems": 3,
              "maxItems": 3,
              "items": {"$ref": "#/$defs/deep_joint_row"}
            },
            {"type": "null"}
          ]
        },
        "turnover_records": {
          "type": "array",
          "items": {"$ref": "#/$defs/step_record"}
        },
        "access_regimes": {
          "oneOf": [
            {"type": "array", "maxItems": 0},
            {
              "type": "array",
              "minItems": 8,
              "maxItems": 8,
              "items": {"$ref": "#/$defs/access_regime"}
            }
          ]
        },
        "arm_complete": {"type": "boolean"},
        "first_failure": {"$ref": "#/$defs/nullable_failure"}
      },
      "allOf": [
        {
          "if": {"properties": {"arm_complete": {"const": true}}},
          "then": {
            "properties": {
              "common_deep_step": {"type": "integer", "minimum": 1},
              "deep_complete": {"const": true},
              "access_regimes": {
                "type": "array",
                "minItems": 8,
                "maxItems": 8,
                "items": {"$ref": "#/$defs/access_regime"}
              },
              "first_failure": {"type": "null"}
            }
          },
          "else": {
            "properties": {
              "first_failure": {"$ref": "#/$defs/failure"}
            }
          }
        },
        {
          "if": {"properties": {"deep_complete": {"const": true}}},
          "then": {
            "properties": {
              "common_deep_step": {"type": "integer", "minimum": 1},
              "turnover_records": {"type": "array", "minItems": 1},
              "deep_joint": {
                "type": "array",
                "minItems": 3,
                "maxItems": 3,
                "items": {"$ref": "#/$defs/deep_joint_row"}
              }
            }
          }
        }
      ]
    }
  }
}
