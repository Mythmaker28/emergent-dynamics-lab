    "arm": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "arm",
        "is_sham",
        "cut_A",
        "cut_B",
        "edge_severed_A",
        "edge_severed_B",
        "clone_checkpoint_sha256",
        "preintervention_state_sha256",
        "operator_application_order",
        "trajectory",
        "mechanically_valid",
        "censor_reason"
      ],
      "properties": {
        "arm": {
          "enum": [
            "C00",
            "C10",
            "C01",
            "C11",
            "SHAM00",
            "SHAM10",
            "SHAM01",
            "SHAM11"
          ]
        },
        "is_sham": {
          "type": "boolean"
        },
        "cut_A": {
          "type": "boolean",
          "description": "Nominal A support assignment; for SHAM arms the same support/operations are applied without severing the edge."
        },
        "cut_B": {
          "type": "boolean",
          "description": "Nominal B support assignment; for SHAM arms the same support/operations are applied without severing the edge."
        },
        "edge_severed_A": {
          "type": "boolean"
        },
        "edge_severed_B": {
          "type": "boolean"
        },
        "clone_checkpoint_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "preintervention_state_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "operator_application_order": {
          "type": "array",
          "items": {
            "enum": [
              "A",
              "B"
            ]
          }
        },
        "trajectory": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/step"
          }
        },
        "mechanically_valid": {
          "type": "boolean"
        },
        "censor_reason": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "C00_arm": {
      "allOf": [
        {
          "$ref": "#/$defs/arm"
        },
        {
          "properties": {
            "arm": {
              "const": "C00"
            },
            "is_sham": {
              "const": false
            },
            "cut_A": {
              "const": false
            },
            "cut_B": {
              "const": false
            },
            "edge_severed_A": {
              "const": false
            },
            "edge_severed_B": {
              "const": false
            },
            "operator_application_order": {
              "const": []
            }
          }
        }
      ]
