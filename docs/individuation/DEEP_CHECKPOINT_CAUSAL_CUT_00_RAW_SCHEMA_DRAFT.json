{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "DEEP-CHECKPOINT-CAUSAL-CUT-00-RAW-v0-draft",
  "title": "DEV-only minimum raw record for a deep-checkpoint local-cut factorial",
  "description": "NON-EXECUTABLE DRAFT. One world is one statistical unit. No outcome field may be populated until exact-checkpoint and local-cut mechanical gates pass under a separately authorized protocol.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "mission",
    "mode",
    "code_commit",
    "prospective_namespace",
    "outcome_firewall",
    "contract_hashes",
    "history_contract",
    "operator_contract",
    "worlds"
  ],
  "properties": {
    "schema": {
      "const": "DEEP-CHECKPOINT-CAUSAL-CUT-00-RAW-v0-draft"
    },
    "mission": {
      "const": "DEEP-CHECKPOINT-CAUSAL-CUT-00"
    },
    "mode": {
      "const": "DEV"
    },
    "code_commit": {
      "$ref": "#/$defs/git_commit"
    },
    "prospective_namespace": {
      "type": "null"
    },
    "outcome_firewall": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "checkpoint_gate_passed",
        "operator_gate_passed",
        "pair_mechanics_gate_passed",
        "outcome_unlock",
        "unlock_audit_sha256"
      ],
      "properties": {
        "checkpoint_gate_passed": {
          "type": "boolean"
        },
        "operator_gate_passed": {
          "type": "boolean"
        },
        "pair_mechanics_gate_passed": {
          "type": "boolean"
        },
        "outcome_unlock": {
          "type": "boolean"
        },
        "unlock_audit_sha256": {
          "oneOf": [
            {
              "$ref": "#/$defs/sha256"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "contract_hashes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "engine",
        "tracker",
        "probe",
        "serializer",
        "operator",
        "sham",
        "analysis_contract",
        "history_contract"
      ],
      "properties": {
        "engine": {
          "$ref": "#/$defs/sha256"
        },
        "tracker": {
          "$ref": "#/$defs/sha256"
        },
        "probe": {
          "$ref": "#/$defs/sha256"
        },
        "serializer": {
          "$ref": "#/$defs/sha256"
        },
        "operator": {
          "$ref": "#/$defs/sha256"
        },
        "sham": {
          "$ref": "#/$defs/sha256"
        },
        "analysis_contract": {
          "$ref": "#/$defs/sha256"
        },
        "history_contract": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "history_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "history_writing_disabled",
        "eta_w",
        "eta_w_zero_from_checkpoint_through_endpoint",
        "external_history_writer_called",
        "new_exposure_dependent_history_term_enabled",
        "passive_copy_policy",
        "passive_copy_code_sha256",
        "decay_transport_parameter_sha256",
        "contract_sha256"
      ],
      "properties": {
        "history_writing_disabled": {
          "const": true
        },
        "eta_w": {
          "const": 0.0
        },
        "eta_w_zero_from_checkpoint_through_endpoint": {
          "const": true
        },
        "external_history_writer_called": {
          "const": false
        },
        "new_exposure_dependent_history_term_enabled": {
          "const": false
        },
        "passive_copy_policy": {
          "const": "ALLOW_UNCHANGED_ENGINE_COPY_OF_PREEXISTING_Mf_ONLY"
        },
        "passive_copy_code_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "decay_transport_parameter_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "contract_sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "operator_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_channel",
        "equation_edge_cut",
        "physical_support_rule",
        "support_uses_diagnostic_identity",
        "state_fields_read",
        "state_fields_written",
        "global_parameters_changed",
        "common_boundary_changed",
        "environment_changed_at_intervention",
        "body_state_changed_at_intervention",
        "probe_changed",
        "clock_changed",
        "cut_A_and_cut_B_same_mechanism",
        "dual_composition_order_independent",
        "matched_sham_definition",
        "qualification_status"
      ],
      "properties": {
        "candidate_channel": {
          "type": "string",
          "minLength": 1
        },
        "equation_edge_cut": {
          "type": "string",
          "minLength": 1
        },
        "physical_support_rule": {
          "type": "string",
          "minLength": 1
        },
        "support_uses_diagnostic_identity": {
          "const": false
        },
        "state_fields_read": {
          "type": "array",
          "items": {
            "enum": [
              "rho",
              "U",
              "V",
              "c",
              "N",
              "C",
              "uptake",
              "Mf",
              "m_plus",
              "m_minus",
              "up_ref"
            ]
          },
          "uniqueItems": true
        },
        "state_fields_written": {
          "type": "array",
          "maxItems": 0,
          "uniqueItems": true
        },
        "global_parameters_changed": {
          "const": false
        },
        "common_boundary_changed": {
          "const": false
        },
        "environment_changed_at_intervention": {
          "const": false
        },
        "body_state_changed_at_intervention": {
          "const": false
        },
        "probe_changed": {
          "const": false
        },
        "clock_changed": {
          "const": false
        },
        "cut_A_and_cut_B_same_mechanism": {
          "const": true
        },
        "dual_composition_order_independent": {
          "const": true
        },
        "matched_sham_definition": {
          "type": "string",
          "minLength": 1
        },
        "qualification_status": {
          "enum": [
            "UNQUALIFIED",
            "QUALIFIED_DEV_MECHANICS"
          ]
        }
      }
    },
    "worlds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/world"
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "outcome_firewall": {
            "properties": {
              "outcome_unlock": {
                "const": false
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "worlds": {
            "items": {
              "properties": {
                "future_responses": {
                  "type": "null"
                }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "outcome_firewall": {
            "anyOf": [
              {
                "properties": {
                  "checkpoint_gate_passed": {
                    "const": false
                  }
                }
              },
              {
                "properties": {
                  "operator_gate_passed": {
                    "const": false
                  }
                }
              },
              {
                "properties": {
                  "pair_mechanics_gate_passed": {
                    "const": false
                  }
                }
              }
            ]
          }
        }
      },
      "then": {
        "properties": {
          "outcome_firewall": {
            "properties": {
              "outcome_unlock": {
                "const": false
              },
              "unlock_audit_sha256": {
                "type": "null"
              }
            }
          },
          "worlds": {
            "items": {
              "properties": {
                "future_responses": {
                  "type": "null"
                }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "outcome_firewall": {
            "properties": {
              "outcome_unlock": {
                "const": true
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "outcome_firewall": {
            "properties": {
              "checkpoint_gate_passed": {
                "const": true
              },
              "operator_gate_passed": {
                "const": true
              },
              "pair_mechanics_gate_passed": {
                "const": true
              },
              "unlock_audit_sha256": {
                "$ref": "#/$defs/sha256"
              }
            }
          },
          "operator_contract": {
            "properties": {
              "qualification_status": {
                "const": "QUALIFIED_DEV_MECHANICS"
              }
            }
          },
          "worlds": {
            "items": {
              "properties": {
                "whole_world_valid": {
                  "const": true
                },
                "all_arms_mechanically_valid": {
                  "const": true
                },
                "arms": {
                  "properties": {
                    "C00": {
                      "properties": {
                        "mechanically_valid": {
                          "const": true
                        },
                        "censor_reason": {
                          "type": "null"
                        }
                      }
                    },
                    "C10": {
                      "properties": {
                        "mechanically_valid": {
                          "const": true
                        },
                        "censor_reason": {
                          "type": "null"
                        }
                      }
                    },
                    "C01": {
                      "properties": {
                        "mechanically_valid": {
                          "const": true
                        },
                        "censor_reason": {
                          "type": "null"
                        }
                      }
                    },
                    "C11": {
                      "properties": {
                        "mechanically_valid": {
                          "const": true
                        },
                        "censor_reason": {
                          "type": "null"
                        }
                      }
                    },
                    "SHAM00": {
                      "properties": {
                        "mechanically_valid": {
                          "const": true
                        },
                        "censor_reason": {
                          "type": "null"
                        }
                      }
                    },
                    "SHAM10": {
                      "properties": {
                        "mechanically_valid": {
                          "const": true
                        },
                        "censor_reason": {
                          "type": "null"
                        }
                      }
                    },
                    "SHAM01": {
                      "properties": {
                        "mechanically_valid": {
                          "const": true
                        },
                        "censor_reason": {
                          "type": "null"
                        }
                      }
                    },
                    "SHAM11": {
                      "properties": {
                        "mechanically_valid": {
                          "const": true
                        },
                        "censor_reason": {
                          "type": "null"
                        }
                      }
                    }
                  }
                },
                "future_responses": {
                  "$ref": "#/$defs/responses"
                }
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "git_commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "finite": {
      "type": "number"
    },
    "point": {
      "type": "array",
      "prefixItems": [
        {
          "$ref": "#/$defs/finite"
        },
        {
          "$ref": "#/$defs/finite"
        }
      ],
      "items": false
    },
    "joint_PM": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "P",
        "M",
        "raw_descriptor_sha256",
        "lineage_evidence_sha256"
      ],
      "properties": {
        "P": {
          "$ref": "#/$defs/finite"
        },
        "M": {
          "$ref": "#/$defs/finite"
        },
        "raw_descriptor_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "lineage_evidence_sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "entity_step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "tracker_id",
        "status",
        "centroid",
        "component_size",
        "rho_mass",
        "body_mask_sha256",
        "core_mask_sha256",
        "halo_mask_sha256",
        "joint_PM"
      ],
      "properties": {
        "label": {
          "enum": [
            "A",
            "B",
            "SENTINEL"
          ]
        },
        "tracker_id": {
          "type": "integer",
          "minimum": 0,
          "description": "Diagnostic only; forbidden from physics, detection, and association."
        },
        "status": {
          "enum": [
            "ALIVE",
            "SPLIT",
            "MERGED",
            "LOST",
            "AMBIGUOUS"
          ]
        },
        "centroid": {
          "$ref": "#/$defs/point"
        },
        "component_size": {
          "type": "integer",
          "minimum": 0
        },
        "rho_mass": {
          "$ref": "#/$defs/finite"
        },
        "body_mask_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "core_mask_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "halo_mask_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "joint_PM": {
          "$ref": "#/$defs/joint_PM"
        }
      }
    },
    "association_edge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tracker_id",
        "component_id",
        "overlap",
        "centroid_distance",
        "size_ratio",
        "overlap_gate",
        "distance_gate",
        "size_gate",
        "compatible",
        "assignment_cost",
        "selected"
      ],
      "properties": {
        "tracker_id": {
          "type": "integer"
        },
        "component_id": {
          "type": "integer"
        },
        "overlap": {
          "$ref": "#/$defs/finite"
        },
        "centroid_distance": {
          "$ref": "#/$defs/finite"
        },
        "size_ratio": {
          "$ref": "#/$defs/finite"
        },
        "overlap_gate": {
          "type": "boolean"
        },
        "distance_gate": {
          "type": "boolean"
        },
        "size_gate": {
          "type": "boolean"
        },
        "compatible": {
          "type": "boolean"
        },
        "assignment_cost": {
          "$ref": "#/$defs/finite"
        },
        "selected": {
          "type": "boolean"
        }
      }
    },
    "state_field_map": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rho",
        "U",
        "V",
        "c",
        "N",
        "C",
        "uptake",
        "Mf"
      ],
      "properties": {
        "rho": {
          "$ref": "#/$defs/finite"
        },
        "U": {
          "$ref": "#/$defs/finite"
        },
        "V": {
          "$ref": "#/$defs/finite"
        },
        "c": {
          "$ref": "#/$defs/finite"
        },
        "N": {
          "$ref": "#/$defs/finite"
        },
        "C": {
