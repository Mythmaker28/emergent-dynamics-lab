        },
        "uptake": {
          "$ref": "#/$defs/finite"
        },
        "Mf": {
          "$ref": "#/$defs/finite"
        }
      }
    },
    "tracker_event": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "step",
        "event",
        "target_labels",
        "component_ids",
        "many_to_many_compatibility_unresolved",
        "evidence_sha256"
      ],
      "properties": {
        "step": {
          "type": "integer",
          "minimum": 0
        },
        "event": {
          "enum": [
            "SPLIT",
            "MERGE",
            "FUSION",
            "LOST",
            "AMBIGUOUS",
            "COMPONENT_SWITCH",
            "GIANT_COMPONENT"
          ]
        },
        "target_labels": {
          "type": "array",
          "items": {
            "enum": [
              "A",
              "B",
              "SENTINEL"
            ]
          },
          "uniqueItems": true
        },
        "component_ids": {
          "type": "array",
          "items": {
            "type": "integer"
          },
          "uniqueItems": true
        },
        "many_to_many_compatibility_unresolved": {
          "type": "boolean"
        },
        "evidence_sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "step",
        "state_sha256",
        "entities",
        "pair_distance",
        "halo_overlap_cells",
        "body_overlap_cells",
        "support_overlap_cells",
        "association_edges",
        "tracker_events",
        "finite",
        "viable",
        "boundary_diagnostics",
        "confinement_diagnostics",
        "common_state_diagnostics",
        "history_write_diagnostics"
      ],
      "properties": {
        "step": {
          "type": "integer",
          "minimum": 0
        },
        "state_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "entities": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": {
            "$ref": "#/$defs/entity_step"
          }
        },
        "pair_distance": {
          "$ref": "#/$defs/finite"
        },
        "halo_overlap_cells": {
          "type": "integer",
          "minimum": 0
        },
        "body_overlap_cells": {
          "type": "integer",
          "minimum": 0
        },
        "support_overlap_cells": {
          "type": "integer",
          "minimum": 0
        },
        "association_edges": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/association_edge"
          }
        },
        "tracker_events": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/tracker_event"
          }
        },
        "finite": {
          "type": "boolean"
        },
        "viable": {
          "type": "boolean"
        },
        "boundary_diagnostics": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "per_field_face_jump",
            "per_field_flux",
            "active_minus_sham"
          ],
          "properties": {
            "per_field_face_jump": {
              "$ref": "#/$defs/state_field_map"
            },
            "per_field_flux": {
              "$ref": "#/$defs/state_field_map"
            },
            "active_minus_sham": {
              "$ref": "#/$defs/state_field_map"
            }
          }
        },
        "confinement_diagnostics": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "per_field_inside_support_change",
            "per_field_outside_support_change",
            "partner_change",
            "sentinel_change"
          ],
          "properties": {
            "per_field_inside_support_change": {
              "$ref": "#/$defs/state_field_map"
            },
            "per_field_outside_support_change": {
              "$ref": "#/$defs/state_field_map"
            },
            "partner_change": {
              "$ref": "#/$defs/state_field_map"
            },
            "sentinel_change": {
              "$ref": "#/$defs/state_field_map"
            }
          }
        },
        "common_state_diagnostics": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "environment_sha256",
            "boundary_sha256",
            "probe_sha256",
            "body_state_sha256",
            "clock",
            "up_ref",
            "world_mean_up"
          ],
          "properties": {
            "environment_sha256": {
              "$ref": "#/$defs/sha256"
            },
            "boundary_sha256": {
              "$ref": "#/$defs/sha256"
            },
            "probe_sha256": {
